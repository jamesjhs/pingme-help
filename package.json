{
  "name": "pingme-help",
  "version": "0.0.1",
  "description": "Zero-bloat privacy-first status service for pingme.help",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/public && cp public/styles.css dist/public/styles.css",
    "start": "npm run build && node dist/server.js",
    "test": "npm run build && node --test dist/test/server.test.js",
    "audit": "npm audit --omit=dev"
  },
  "keywords": [
    "privacy",
    "status",
    "sqlite",
    "turnstile"
  ],
  "author": "GitHub Copilot",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "better-sqlite3-multiple-ciphers": "^12.9.0",
    "dotenv": "^17.4.2",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "typescript": "^6.0.3"
  }
}
